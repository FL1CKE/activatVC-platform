APP_NAME="Startup Analyzer"
APP_VERSION="0.1.0"
DEBUG=false

# Database — PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://admin:adminpassword@localhost:5433/agents_platform

# LLM — основной провайдер Anthropic Claude
DEFAULT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Fallback — при 403/401 от основного провайдера
FALLBACK_LLM_PROVIDER=openai
FALLBACK_LLM_MODEL=gpt-4.1
OPENAI_API_KEY=sk-proj-...

# Google (опционально, если агент настроен на google)
GOOGLE_API_KEY=

# Master agent integration (startup-automation)
MASTER_AGENT_BASE_URL=http://127.0.0.1:3100
MASTER_AGENT_TIMEOUT=30
ORCHESTRATION_MODE=standalone

STORAGE_PATH=./storage
PROMPTS_PATH=./storage/prompts
REPORTS_PATH=./storage/reports

SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — разрешённые origins (через запятую или * для dev)
# Включает Vite dev server и Node.js chat server
CORS_ORIGINS_RAW=http://localhost:5173,http://localhost:4173,http://localhost:3001

# Frontend — путь к собранному Vite build (для production).
# Оставьте пустым в dev-режиме (Vite запускается отдельно).
# Пример для production: FRONTEND_DIR=../ventureiq/dist
FRONTEND_DIR=
