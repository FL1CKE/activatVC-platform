# Copy to .env.vm on the Ubuntu VM and fill values.
# This file is for docker compose variable substitution and runtime env.

# Host port mappings
APP_HOST_PORT=80
POSTGRES_HOST_PORT=5433
MINIO_API_HOST_PORT=9100
MINIO_CONSOLE_HOST_PORT=9101

# App runtime
PORT=3000
APP_PUBLIC_URL=http://<VM_PUBLIC_IP_OR_DOMAIN>
APP_INTERNAL_URL=http://127.0.0.1:3000
AGENT_EXECUTION_MODE=mock
AGENTS_PLATFORM_URL=http://127.0.0.1:8000

# Database (inside docker network)
DATABASE_URL=postgresql://admin:adminpassword@postgres:5432/activat_db?schema=public

# MinIO
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://<VM_PUBLIC_IP_OR_DOMAIN>:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=startups
