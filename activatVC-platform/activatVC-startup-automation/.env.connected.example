# startup-automation local deployment template
# Copy to .env.connected and set real API keys.

APP_HOST_PORT=3100
APP_CONTAINER_PORT=3000

POSTGRES_HOST_PORT=5433
MINIO_API_HOST_PORT=9100
MINIO_CONSOLE_HOST_PORT=9101

PORT=3000
APP_PUBLIC_URL=http://127.0.0.1:3100
APP_INTERNAL_URL=http://127.0.0.1:3000

DATABASE_URL=postgresql://admin:adminpassword@postgres:5432/activat_db?schema=public

S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://127.0.0.1:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=startups

# Integration mode:
# mock     -> startup-automation runs internal mock agents
# external -> startup-automation dispatches to agents_platform-main
AGENT_EXECUTION_MODE=external
AGENTS_PLATFORM_URL=http://agents_platform_app:8000

# Master orchestrator LLM (для генерации IC Decision Memo)
# deterministic -> детерминистическая агрегация без LLM
# llm           -> LLM-синтез + детерминистический fallback
MASTER_ORCHESTRATOR_MODE=deterministic
MASTER_ORCHESTRATOR_PROMPT_PATH=./config/master_orchestrator_prompt_v5.2.md
MASTER_ORCHESTRATOR_PROVIDER=anthropic
MASTER_ORCHESTRATOR_MODEL=claude-sonnet-4-20250514

# Anthropic API key (required if MASTER_ORCHESTRATOR_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
