# ─── activatVC Full Stack — Root .env ────────────────────────────────────────
# Используется docker-compose.yml
# cp .env.example .env

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...       # fallback
GOOGLE_API_KEY=                  # опционально

# Security
SECRET_KEY=change-me-in-production-please

# Frontend origin (для CORS в продакшне)
FRONTEND_ORIGIN=http://localhost:5173

# Master Agent (если используется интеграция с activatVC-startup-automation)
MASTER_AGENT_BASE_URL=http://localhost:3100
